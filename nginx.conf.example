# EVL-4EZR Command Center - Nginx Reverse Proxy Configuration Example
# Save this file (e.g., as /etc/nginx/sites-available/evl4-dsc) and create a symlink to sites-enabled.

# 1. HTTP Redirect to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name alarm.yourdomain.com;

    # Redirect all HTTP requests to HTTPS
    return 301 https://$host$request_uri;
}

# 2. HTTPS Server Block
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name alarm.yourdomain.com;

    # SSL Certificate Paths (Adjust to your SSL provider, e.g., Let's Encrypt / Certbot)
    ssl_certificate /etc/letsencrypt/live/alarm.yourdomain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/alarm.yourdomain.com/privkey.pem;

    # Recommended Modern SSL Settings
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384';
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # Security Headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Content-Security-Policy "default-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data:; connect-src 'self' wss://alarm.yourdomain.com https://alarm.yourdomain.com;" always;

    # Choose ONE of the serving strategies below:

    # =========================================================================
    # OPTION A: Nginx Serves Static Assets (Recommended for Production/Performance)
    # =========================================================================
    # Set the root to the static assets directory. If using Docker, copy the
    # static folder contents (like `frontend/dist`) to this directory on the host.
    root /var/www/evl4-dsc/static;
    index index.html;

    # Serve the React app frontend files
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Serve Static Assets with Aggressive Caching
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, no-transform";
        try_files $uri =404;
    }

    # =========================================================================
    # OPTION B: Nginx Proxies All Assets directly to FastAPI (Simpler setup)
    # =========================================================================
    # Uncomment the following block if you prefer to let FastAPI serve the frontend.
    # Note: Since Vite builds assets under `/assets/` but FastAPI mounts static assets at `/static/`, 
    # we explicitly rewrite `/assets/` requests to `/static/assets/` on the FastAPI server.
    #
    # location / {
    #     proxy_pass http://127.0.0.1:8000;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }
    #
    # location /assets/ {
    #     proxy_pass http://127.0.0.1:8000/static/assets/;
    #     proxy_set_header Host $host;
    #     proxy_set_header X-Real-IP $remote_addr;
    #     proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    #     proxy_set_header X-Forwarded-Proto $scheme;
    # }

    # =========================================================================
    # COMMON PROXY PATHS (Required for both Option A and Option B)
    # =========================================================================

    # Proxy REST API commands
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Disable buffering for API responses
        proxy_buffering off;
    }

    # Proxy WebSocket connections (CRITICAL: Required for live panel updates)
    location /ws {
        proxy_pass http://127.0.0.1:8000/ws;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Keep the WebSocket connection alive without timeouts (1 day)
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
    }
}
